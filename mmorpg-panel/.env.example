# ──────── Database ────────
# SQLite (zero-config, default for dev):
DATABASE_URL="file:./dev.db"

# MySQL (for production / vsro-style setups):
# DATABASE_URL="mysql://user:password@localhost:3306/mmorpg_panel"

# PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/mmorpg_panel"
#
# After changing this, also change `provider` in prisma/schema.prisma to match.

# ──────── Sessions ────────
# Must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-random-32-character-string-or-longer"

# ──────── Site ────────
NEXT_PUBLIC_SITE_NAME="My MMORPG Server"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────── Stripe ────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────── PayPal ────────
# Get credentials from https://developer.paypal.com/dashboard/applications/
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# Use "https://api-m.sandbox.paypal.com" for testing,
# "https://api-m.paypal.com" for live
PAYPAL_API_BASE="https://api-m.sandbox.paypal.com"

# ──────── Hypotatima ────────
# Configure for your Hypotatima merchant account
HYPOTATIMA_MERCHANT_ID=""
HYPOTATIMA_API_KEY=""
HYPOTATIMA_API_BASE="https://api.hypotatima.example/v1"

# ──────── Discord OAuth ────────
# 1. Create an app: https://discord.com/developers/applications
# 2. OAuth2 → Redirects → add the URL below
# 3. OAuth2 → copy Client ID and Client Secret
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"
# Set DISCORD_DISABLED=1 to force-hide Discord login even if the vars above
# are set. Useful for public demos.
DISCORD_DISABLED=""

# ──────── Initial admin (used by seed script) ────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_EMAIL="admin@localhost"
SEED_ADMIN_PASSWORD="changeme"
